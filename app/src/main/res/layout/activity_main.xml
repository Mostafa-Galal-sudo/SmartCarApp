<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/card_dark"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SMART CAR"
            android:textColor="@color/accent_blue"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/tvStatusIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textColor="@color/status_red"
            android:textSize="22sp"
            android:layout_marginEnd="12dp" />

        <Button
            android:id="@+id/btnOpenBluetooth"
            android:layout_width="72dp"
            android:layout_height="36dp"
            android:text="BT"
            android:textSize="12sp"
            android:textStyle="bold"
            android:backgroundTint="@color/accent_blue"
            android:textColor="@color/background_dark" />
    </LinearLayout>

    <!-- MODE LABEL -->
    <TextView
        android:id="@+id/tvModeLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="// MODE: MANUAL"
        android:textColor="@color/text_dim"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        android:gravity="center"
        android:paddingVertical="6dp"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <!-- MODE CONTAINER -->
    <FrameLayout
        android:id="@+id/modeContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvModeLabel"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <!-- MANUAL LAYOUT -->
        <LinearLayout
            android:id="@+id/layoutManual"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="visible">

            <!-- D-PAD -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <!-- FWD -->
                <Button
                    android:id="@+id/btnFwd"
                    android:layout_width="110dp"
                    android:layout_height="90dp"
                    android:text="FWD"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_blue"
                    android:backgroundTint="@color/button_dark"
                    android:letterSpacing="0.1" />

                <!-- LEFT / STOP / RIGHT -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="6dp">

                    <Button
                        android:id="@+id/btnLeft"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:text="LEFT"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:backgroundTint="@color/button_dark"
                        android:layout_marginEnd="6dp" />

                    <Button
                        android:id="@+id/btnStop"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:text="■"
                        android:textSize="28sp"
                        android:textColor="@color/background_dark"
                        android:backgroundTint="@color/accent_orange" />

                    <Button
                        android:id="@+id/btnRight"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:text="RIGHT"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:backgroundTint="@color/button_dark"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <!-- BACK -->
                <Button
                    android:id="@+id/btnBack"
                    android:layout_width="110dp"
                    android:layout_height="90dp"
                    android:text="BACK"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_blue"
                    android:backgroundTint="@color/button_dark"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <!-- AUTO / MANUAL TOGGLE -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <Button
                    android:id="@+id/btnAuto"
                    android:layout_width="130dp"
                    android:layout_height="44dp"
                    android:text="AUTO MODE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/background_dark"
                    android:backgroundTint="@color/accent_blue"
                    android:layout_marginEnd="12dp" />

                <Button
                    android:id="@+id/btnMan"
                    android:layout_width="130dp"
                    android:layout_height="44dp"
                    android:text="MANUAL MODE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_blue"
                    android:backgroundTint="@color/button_dark" />
            </LinearLayout>
        </LinearLayout>

        <!-- BODY FOLLOWER LAYOUT -->
        <LinearLayout
            android:id="@+id/layoutBody"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <Button
                android:id="@+id/btnBodyActivate"
                android:layout_width="220dp"
                android:layout_height="70dp"
                android:text="ACTIVATE"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/background_dark"
                android:backgroundTint="@color/accent_blue" />

            <TextView
                android:id="@+id/lblBodyStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="// BODY FOLLOWER ACTIVE"
                android:textColor="@color/status_green"
                android:textSize="14sp"
                android:letterSpacing="0.05"
                android:layout_marginTop="20dp"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- GYRO LAYOUT -->
        <LinearLayout
            android:id="@+id/layoutGyro"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SENSITIVITY"
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <SeekBar
                android:id="@+id/sliderSensitivity"
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:max="40"
                android:progress="15"
                android:layout_marginVertical="16dp" />

            <TextView
                android:id="@+id/lblGyroStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FLAT"
                android:textColor="@color/accent_blue"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginTop="32dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="@color/card_dark"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnNavManual"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="MANUAL"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/accent_blue"
            android:backgroundTint="@color/button_dark" />

        <Button
            android:id="@+id/btnNavBody"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="BODY"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/accent_blue"
            android:backgroundTint="@color/button_dark" />

        <Button
            android:id="@+id/btnNavGyro"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="GYRO"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/accent_blue"
            android:backgroundTint="@color/button_dark" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
