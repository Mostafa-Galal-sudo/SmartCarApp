<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark"
    android:padding="8dp">

    <!-- ===== TOP BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnOpenBluetooth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BLUETOOTH"
            android:textSize="12sp"
            android:backgroundTint="@color/button_dark" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <TextView
            android:id="@+id/tvStatusIndicator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/circle_red"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvModeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="// MODE: IDLE"
            android:textColor="@color/text_dim"
            android:textSize="14sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- ===== NAVIGATION BAR (8 modes) ===== -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnNavManual"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="MANUAL"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="@color/button_dark" />

            <Button
                android:id="@+id/btnNavBody"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="BODY"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="@color/button_dark" />

            <Button
                android:id="@+id/btnNavGyro"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="GYRO"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="@color/button_dark" />

            <Button
                android:id="@+id/btnNavVoice"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="VOICE"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="@color/button_dark" />

            <Button
                android:id="@+id/btnNavLine"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="LINE"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="@color/button_dark" />

            <Button
                android:id="@+id/btnNavClap"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="CLAP"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="@color/button_dark" />

            <Button
                android:id="@+id/btnNavMusic"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="MUSIC"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="@color/button_dark" />

            <Button
                android:id="@+id/btnNavDraw"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="DRAW"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="@color/button_dark" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ===== MODE CONTENT AREA ===== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp">

        <!-- MODE: MANUAL -->
        <LinearLayout
            android:id="@+id/layoutManual"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnAuto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AUTO"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="@color/button_dark" />

                <Button
                    android:id="@+id/btnMan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAN"
                    android:backgroundTint="@color/button_dark" />
            </LinearLayout>

            <Button
                android:id="@+id/btnFwd"
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:text="UP"
                android:textSize="20sp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/button_dark" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnLeft"
                    android:layout_width="100dp"
                    android:layout_height="80dp"
                    android:text="LEFT"
                    android:textSize="20sp"
                    android:layout_marginEnd="16dp"
                    android:backgroundTint="@color/button_dark" />

                <Button
                    android:id="@+id/btnStop"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:text="STOP"
                    android:textSize="18sp"
                    android:backgroundTint="@color/status_red" />

                <Button
                    android:id="@+id/btnRight"
                    android:layout_width="100dp"
                    android:layout_height="80dp"
                    android:text="RIGHT"
                    android:textSize="20sp"
                    android:layout_marginStart="16dp"
                    android:backgroundTint="@color/button_dark" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBack"
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:text="DOWN"
                android:textSize="20sp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/button_dark" />
        </LinearLayout>

        <!-- MODE: BODY FOLLOWER -->
        <LinearLayout
            android:id="@+id/layoutBody"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <Button
                android:id="@+id/btnBodyActivate"
                android:layout_width="200dp"
                android:layout_height="120dp"
                android:text="ACTIVATE\nPERSON TRACKING"
                android:textSize="18sp"
                android:backgroundTint="@color/status_green" />

            <TextView
                android:id="@+id/lblBodyStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="// SCANNING..."
                android:textColor="@color/status_green"
                android:textSize="16sp"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- MODE: GYRO -->
        <LinearLayout
            android:id="@+id/layoutGyro"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/lblGyroStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FLAT"
                android:textSize="32sp"
                android:textColor="@color/text_white"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="SENSITIVITY"
                android:textColor="@color/text_dim" />

            <SeekBar
                android:id="@+id/sliderSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="50"
                android:progress="15" />
        </LinearLayout>

        <!-- MODE: VOICE AI -->
        <LinearLayout
            android:id="@+id/layoutVoice"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <Button
                android:id="@+id/btnMic"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:text="MIC"
                android:textSize="24sp"
                android:backgroundTint="@color/button_dark" />

            <TextView
                android:id="@+id/lblVoiceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="PRESS TO SPEAK"
                android:textColor="@color/text_dim"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/lblRecognizedText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="@color/text_white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/lblConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="@color/text_dim"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/layoutConfirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/lblConfirmQuestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Did you mean...?"
                    android:textColor="@color/text_white"
                    android:textSize="16sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/btnConfirmYes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YES"
                        android:layout_marginEnd="16dp"
                        android:backgroundTint="@color/status_green" />

                    <Button
                        android:id="@+id/btnConfirmNo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NO"
                        android:backgroundTint="@color/status_red" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- MODE: LINE FOLLOWER (Camera) -->
        <LinearLayout
            android:id="@+id/layoutLine"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <androidx.camera.view.PreviewView
                android:id="@+id/previewLine"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvLineStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="// POINT CAMERA AT LINE"
                android:textColor="@color/text_dim"
                android:textSize="14sp"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="DARKNESS THRESHOLD"
                android:textColor="@color/text_dim"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/sliderLineThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="255"
                android:progress="80" />

            <Button
                android:id="@+id/btnLineStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="START TRACKING"
                android:backgroundTint="@color/status_green" />
        </LinearLayout>

        <!-- MODE: CLAP CONTROL -->
        <LinearLayout
            android:id="@+id/layoutClap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <Button
                android:id="@+id/btnClapMic"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:text="CLAP"
                android:textSize="32sp"
                android:backgroundTint="@color/button_dark" />

            <TextView
                android:id="@+id/tvClapStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="TAP TO ACTIVATE CLAP LISTENER"
                android:textColor="@color/text_dim"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvClapCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="@color/status_green"
                android:textSize="18sp"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="1 CLAP = STOP | 2 CLAPS = FORWARD | 3 CLAPS = BACKWARD"
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- MODE: MUSIC RHYTHM -->
        <LinearLayout
            android:id="@+id/layoutMusic"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <Button
                android:id="@+id/btnMusicStart"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:text="BEAT"
                android:textSize="32sp"
                android:backgroundTint="@color/button_dark" />

            <TextView
                android:id="@+id/tvMusicStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="TAP TO START RHYTHM MODE"
                android:textColor="@color/text_dim"
                android:textSize="14sp" />

            <View
                android:id="@+id/visualizerView"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:background="@color/button_dark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="CAR DANCES TO THE BEAT"
                android:textColor="@color/text_dim"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- MODE: DRAW PATH -->
        <LinearLayout
            android:id="@+id/layoutDraw"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <FrameLayout
                android:id="@+id/drawPathContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/button_dark" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnDrawPlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLAY"
                    android:layout_marginEnd="16dp"
                    android:backgroundTint="@color/status_green" />

                <Button
                    android:id="@+id/btnDrawClear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLEAR"
                    android:backgroundTint="@color/status_red" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvDrawStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="DRAW A PATH WITH YOUR FINGER"
                android:textColor="@color/text_dim"
                android:textSize="12sp" />
        </LinearLayout>

    </FrameLayout>
</LinearLayout>
