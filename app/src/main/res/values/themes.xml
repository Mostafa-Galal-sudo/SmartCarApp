<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SmartCar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color (Cyan neon) -->
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/neon_cyan</item>
        <item name="colorOnPrimary">@color/cyber_black</item>

        <!-- Secondary brand color (Magenta neon) -->
        <item name="colorSecondary">@color/neon_magenta</item>
        <item name="colorSecondaryVariant">@color/neon_magenta</item>
        <item name="colorOnSecondary">@color/cyber_black</item>

        <!-- Backgrounds -->
        <item name="android:colorBackground">@color/cyber_dark</item>
        <item name="colorSurface">@color/cyber_panel</item>
        <item name="colorError">@color/neon_hot_pink</item>

        <!-- Text -->
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnError">@color/cyber_black</item>

        <!-- Status bar & Navigation bar -->
        <item name="android:statusBarColor">@color/cyber_black</item>
        <item name="android:navigationBarColor">@color/cyber_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/cyber_dark</item>

        <!-- Button style override -->
        <item name="materialButtonStyle">@style/CyberButton</item>
    </style>

    <!-- Cyberpunk Button Style -->
    <style name="CyberButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="backgroundTint">@color/cyber_panel</item>
        <item name="strokeColor">@color/neon_cyan</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Neon Glow Button (Active state) -->
    <style name="CyberButton.Active" parent="CyberButton">
        <item name="backgroundTint">@color/neon_cyan</item>
        <item name="android:textColor">@color/cyber_black</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Danger Button (Red neon) -->
    <style name="CyberButton.Danger" parent="CyberButton">
        <item name="android:textColor">@color/neon_hot_pink</item>
        <item name="strokeColor">@color/neon_hot_pink</item>
    </style>

    <!-- Success Button (Green neon) -->
    <style name="CyberButton.Success" parent="CyberButton">
        <item name="android:textColor">@color/neon_green</item>
        <item name="strokeColor">@color/neon_green</item>
    </style>
</resources>
